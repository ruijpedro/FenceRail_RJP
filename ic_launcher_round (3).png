<!DOCTYPE html>
<html lang="pt">
<head>
<meta charset="UTF-8" />
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>FenceRail_RJP</title>
<style>
:root{--azul:#002d5e;--azul2:#004f9f;--azul3:#0b3b78;--claro:#eef2f7;--texto:#102033;--cyan:#74c8ff}
*{margin:0;padding:0;box-sizing:border-box}
body{font-family:Arial,Helvetica,sans-serif;background:var(--claro);color:var(--texto);min-height:100vh}
.header{background:linear-gradient(135deg,#001e44,#004f9f);color:#fff;padding:22px 22px 26px;border-bottom-left-radius:28px;border-bottom-right-radius:28px;box-shadow:0 8px 24px rgba(0,30,68,.28);position:relative;overflow:hidden}
.header:after{content:"";position:absolute;right:-70px;bottom:-80px;width:360px;height:220px;background:linear-gradient(120deg,rgba(255,255,255,.08),rgba(255,255,255,0));transform:rotate(-10deg);border-radius:40px}
.header-row{display:flex;align-items:center;gap:18px;position:relative;z-index:1}
.logo-top{width:92px;height:92px;background:#fff;border-radius:18px;object-fit:contain;padding:6px;box-shadow:0 6px 16px rgba(0,0,0,.22)}
.header h1{font-size:25px;line-height:1.08;font-weight:900;letter-spacing:.3px;text-transform:uppercase}
.header p{margin-top:7px;font-size:16px;font-weight:700;opacity:.95}.header .autor{font-weight:400}.header .autor b{color:var(--cyan)}
.container{padding:20px 16px 16px}.hero{background:#fff;border-radius:28px;padding:22px 16px 24px;text-align:center;box-shadow:0 8px 28px rgba(0,0,0,.10);margin-bottom:18px}.logo-main{width:190px;max-width:70%;object-fit:contain;margin:0 auto 14px;display:block}.hero h2{font-size:31px;line-height:1.05;color:var(--azul);font-weight:900}.decor{display:flex;align-items:center;justify-content:center;gap:10px;margin:10px 0 8px}.decor:before,.decor:after{content:"";height:3px;width:76px;background:#8fd2ff;border-radius:8px}.decor span{width:10px;height:10px;background:#74c8ff;border-radius:50%}.hero p{font-size:18px;color:#31445c}
.menu{display:block}.menu-btn{width:100%;background:#fff;border:0;border-radius:18px;padding:17px 18px;margin-top:12px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 4px 13px rgba(0,0,0,.08);color:var(--azul);font-size:20px;font-weight:900;text-align:left}.menu-left{display:flex;align-items:center;gap:16px}.menu-icon{width:58px;height:58px;border-radius:14px;background:#eff6ff;display:flex;align-items:center;justify-content:center;font-size:30px;color:var(--azul)}.arrow{font-size:30px}.card{background:#fff;border-radius:22px;padding:18px;margin-bottom:16px;box-shadow:0 5px 16px rgba(0,0,0,.09)}.section-title{font-size:22px;font-weight:900;color:var(--azul);margin-bottom:12px}.hidden{display:none}label{display:block;margin-top:13px;margin-bottom:6px;font-weight:800;color:#17385e}input,select,textarea{width:100%;padding:13px 14px;border-radius:14px;border:1px solid #c8d3df;font-size:15px;background:#fff}textarea{min-height:88px;resize:vertical}.btn{width:100%;border:0;border-radius:16px;padding:15px;margin-top:14px;font-size:16px;font-weight:900;color:#fff;background:#0057a3}.btn.green{background:#168039}.btn.dark{background:#102033}.btn.orange{background:#d97706}.btn.light{background:#1b84c6}.estado{margin-top:14px;padding:12px;border-radius:14px;text-align:center;font-weight:900}.bom{background:#d8f5df;color:#166534}.razoavel{background:#fff3c4;color:#8a6200}.mau{background:#ffd8a8;color:#a34700}.critico{background:#ffc9c9;color:#8b0000}.small{margin-top:8px;color:#607080;font-size:13px}.bottom-brand{margin:8px 0 0;background:linear-gradient(135deg,#002d5e,#004f9f);color:#fff;padding:16px 18px;border-radius:20px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 5px 16px rgba(0,30,68,.25)}.bottom-left{display:flex;align-items:center;gap:14px}.train{width:50px;height:50px;border-radius:50%;border:2px solid rgba(255,255,255,.45);display:flex;align-items:center;justify-content:center;font-size:27px}.bottom-brand h3{font-size:25px;line-height:1}.bottom-brand p{font-size:15px;margin-top:3px;opacity:.92}.mini-logo{height:58px;width:58px;object-fit:contain;filter:brightness(0) invert(1)}.nav{position:sticky;bottom:0;background:#fff;margin:12px -16px -16px;padding:10px 8px 8px;display:flex;justify-content:space-around;box-shadow:0 -6px 20px rgba(0,0,0,.08);border-top-left-radius:22px;border-top-right-radius:22px}.nav button{background:transparent;border:0;color:#334155;font-size:12px;font-weight:700}.nav .ico{display:block;font-size:24px;color:var(--azul);margin-bottom:2px}.footer-note{text-align:center;color:#789;font-size:12px;padding:12px 0 18px}@media(max-width:380px){.header h1{font-size:21px}.logo-top{width:78px;height:78px}.hero h2{font-size:27px}.menu-btn{font-size:18px}.menu-icon{width:52px;height:52px}}
</style>
</head>
<body>
<header class="header">
  <div class="header-row">
    <img class="logo-top" src="logo_rjp.png" alt="RJP">
    <div>
      <h1>Inspeção de Vedações</h1>
      <p>Manutenção Ferroviária</p>
      <p class="autor">Autor: <b>RJP</b></p>
    </div>
  </div>
</header>
<main class="container">
  <section id="home">
    <div class="hero">
      <img class="logo-main" src="logo_rjp.png" alt="RJP">
      <h2>Inspeção de Vedações</h2>
      <div class="decor"><span></span></div>
      <p>Inspeção e Cadastro de Vedações</p>
    </div>
    <div class="menu">
      <button class="menu-btn" onclick="mostrar('cadastro')"><span class="menu-left"><span class="menu-icon">☑</span>Novo Cadastro</span><span class="arrow">›</span></button>
      <button class="menu-btn" onclick="mostrar('cadastro')"><span class="menu-left"><span class="menu-icon">⌕</span>Nova Inspeção</span><span class="arrow">›</span></button>
      <button class="menu-btn" onclick="mostrar('relatorios')"><span class="menu-left"><span class="menu-icon">▥</span>Relatórios</span><span class="arrow">›</span></button>
      <button class="menu-btn" onclick="mostrar('mapa')"><span class="menu-left"><span class="menu-icon">⌖</span>Mapa</span><span class="arrow">›</span></button>
      <button class="menu-btn" onclick="sincronizarSheets()"><span class="menu-left"><span class="menu-icon">XLS</span>Exportar Excel</span><span class="arrow">›</span></button>
    </div>
  </section>
  <section id="cadastro" class="hidden">
    <div class="card"><div class="section-title">Dados da Vedação</div>
      <label>Linha</label><input id="linha" placeholder="Ex: Linha do Oeste">
      <label>Troço</label><input id="troco" placeholder="Ex: Meleças - Louriçal">
      <label>PK Inicial</label><input id="pkIni" placeholder="Ex: 21+204">
      <label>PK Final</label><input id="pkFim" placeholder="Ex: 21+262">
      <label>Lado</label><select id="lado"><option>Esquerdo</option><option>Direito</option><option>Ambos</option></select>
      <label>Tipo segundo Norma</label><select id="tipoNorma"><option>Vedação Plena Via Zona Urbana</option><option>Vedação Plena Via Zona Rural</option><option>Vedação Estações/Apeadeiros</option><option>Outro / Cadastro Existente</option></select>
      <label>Tipologia / Tipo</label><select id="tipologia"><option>Rede Electrossoldada</option><option>Muro em Betão</option><option>Alvenaria Confinante</option><option>Muro em Betão Confinante</option><option>Painel de Rede Electrozincada</option><option>Muro em Betão e Rede</option><option>Rede Simples Torção</option><option>Rural - Rede 160/9/15</option><option>Urbana - Tipologia I</option><option>Urbana - Tipologia II</option><option>Portão</option><option>Porta de Homem</option></select>
      <label>Estado de Conservação</label><select id="estado" onchange="estadoCor()"><option>Bom</option><option>Razoável</option><option>Mau</option><option>Crítico</option></select>
      <div id="estadoBox" class="estado bom">Estado Bom</div>
      <label>Observações</label><textarea id="obs" placeholder="Observações técnicas / anomalias / risco observado"></textarea>
      <label>Ação de Manutenção</label><textarea id="acao" placeholder="Reparação, substituição, limpeza, reforço..."></textarea>
      <button class="btn light" onclick="gpsInicio()">Marcar GPS Início</button><div class="small" id="gps1">GPS início não registado</div>
      <button class="btn light" onclick="gpsFim()">Marcar GPS Fim</button><div class="small" id="gps2">GPS fim não registado</div>
      <button class="btn green" onclick="guardarLocal()">Guardar na APP</button>
      <button class="btn" onclick="sincronizarSheets()">Sincronizar</button>
      <button class="btn orange" onclick="gerarPdfDrive()">Gerar PDF / Guardar Drive / Partilhar</button>
      <button class="btn dark" onclick="mostrar('home')">Voltar ao Início</button>
      <div class="small" id="msg">Sem sincronização efetuada.</div>
    </div>
  </section>
  <section id="relatorios" class="hidden"><div class="card"><div class="section-title">Relatórios</div><p>Os relatórios são gerados no final da inspeção e guardados no Google Drive.</p><button class="btn dark" onclick="mostrar('home')">Voltar</button></div></section>
  <section id="mapa" class="hidden"><div class="card"><div class="section-title">Mapa</div><p>O mapa será ligado aos pontos GPS de início/fim das vedações.</p><button class="btn dark" onclick="mostrar('home')">Voltar</button></div></section>
  <div class="bottom-brand"><div class="bottom-left"><div class="train">🚆</div><div><h3>Vedações</h3><p>Ambiente Ferroviário</p></div></div><img class="mini-logo" src="logo_rjp.png" alt="RJP"></div>
  <div class="nav"><button onclick="mostrar('home')"><span class="ico">⌂</span>Início</button><button onclick="mostrar('cadastro')"><span class="ico">▣</span>Inspeções</button><button onclick="mostrar('relatorios')"><span class="ico">▥</span>Relatórios</button><button><span class="ico">🔔</span>Alertas</button><button><span class="ico">⚙</span>Config.</button></div>
  <div class="footer-note">RJP Rail Suite • FenceRail_RJP</div>
</main>
<script>
const SCRIPT_URL="https://script.google.com/macros/s/AKfycbwfXqxd1vab0H7H0IUSYQQvO05W2qirTGGTP0AfctDBBSo5-V9GHgKDqdaBF3o4LANz/exec";
let gpsInicioValor="";let gpsFimValor="";let ultimoPdfUrl="";
function mostrar(id){['home','cadastro','relatorios','mapa'].forEach(s=>document.getElementById(s).classList.add('hidden'));document.getElementById(id).classList.remove('hidden');window.scrollTo(0,0)}
function estadoCor(){const estado=document.getElementById('estado').value;const box=document.getElementById('estadoBox');box.className='estado';if(estado==='Bom')box.classList.add('bom');if(estado==='Razoável')box.classList.add('razoavel');if(estado==='Mau')box.classList.add('mau');if(estado==='Crítico')box.classList.add('critico');box.innerHTML='Estado '+estado}
function gpsInicio(){navigator.geolocation.getCurrentPosition(p=>{gpsInicioValor=p.coords.latitude.toFixed(6)+','+p.coords.longitude.toFixed(6);document.getElementById('gps1').innerHTML=gpsInicioValor},()=>alert('Não foi possível obter GPS.'),{enableHighAccuracy:true,timeout:10000})}
function gpsFim(){navigator.geolocation.getCurrentPosition(p=>{gpsFimValor=p.coords.latitude.toFixed(6)+','+p.coords.longitude.toFixed(6);document.getElementById('gps2').innerHTML=gpsFimValor},()=>alert('Não foi possível obter GPS.'),{enableHighAccuracy:true,timeout:10000})}
function recolherDados(){return{linha:document.getElementById('linha').value,troco:document.getElementById('troco').value,pkIni:document.getElementById('pkIni').value,pkFim:document.getElementById('pkFim').value,lado:document.getElementById('lado').value,tipoNorma:document.getElementById('tipoNorma').value,tipologia:document.getElementById('tipologia').value,estado:document.getElementById('estado').value,obs:document.getElementById('obs').value,acao:document.getElementById('acao').value,gpsInicio:gpsInicioValor,gpsFim:gpsFimValor}}
function guardarLocal(){const dados=recolherDados();let lista=JSON.parse(localStorage.getItem('fencerail')||'[]');lista.push(dados);localStorage.setItem('fencerail',JSON.stringify(lista));alert('Inspeção guardada na APP.')}
function sincronizarSheets(){const dados=recolherDados();fetch(SCRIPT_URL,{method:'POST',mode:'no-cors',headers:{'Content-Type':'application/json'},body:JSON.stringify(dados)});document.getElementById('msg').innerHTML='Sincronização enviada para Google Sheets.';alert('Sincronização enviada.')}
function gerarPdfDrive(){const dados=recolherDados();fetch(SCRIPT_URL,{method:'POST',headers:{'Content-Type':'text/plain'},body:JSON.stringify(dados)}).then(r=>r.json()).then(res=>{if(res.status==='OK'){ultimoPdfUrl=res.pdf;document.getElementById('msg').innerHTML='PDF guardado no Google Drive.';const texto='Inspeção de Vedações - FenceRail_RJP\n\nLinha: '+dados.linha+'\nTroço: '+dados.troco+'\nPK: '+dados.pkIni+' a '+dados.pkFim+'\n\nPDF: '+ultimoPdfUrl;if(navigator.share){navigator.share({title:'Inspeção de Vedações',text:texto,url:ultimoPdfUrl}).catch(()=>{})}else{window.location.href='https://wa.me/?text='+encodeURIComponent(texto)}}else{alert('Erro ao gerar PDF: '+res.erro)}}).catch(err=>alert('Erro ao comunicar com Google Drive: '+err))}
</script>
</body>
</html>
